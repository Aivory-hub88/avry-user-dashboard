# ============================================================================
# Supabase Auth (centralized across the whole platform)
# ============================================================================
# All frontends authenticate via Supabase. The browser persists the session in
# localStorage and sends the access token as a Bearer token to the services.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================================================
# Microservice URLs
# ============================================================================
# Shared fallback base URL used when a specific service URL is not set.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081

# Per-service base URLs (no trailing slash). In production each service has its
# own domain. When unset, they fall back to NEXT_PUBLIC_API_BASE_URL.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8081
NEXT_PUBLIC_DIAGNOSTICS_URL=http://localhost:8084
NEXT_PUBLIC_BLUEPRINT_URL=http://localhost:8085
NEXT_PUBLIC_WORKFLOWS_URL=http://localhost:8082
NEXT_PUBLIC_PAYMENTS_URL=http://localhost:3030
NEXT_PUBLIC_ROADMAP_URL=http://localhost:8088

# ============================================================================
# Midtrans Configuration
# ============================================================================
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-<your-client-key>
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# ============================================================================
# App Configuration
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:9000

# Console App URL (nextjs-console app)
NEXT_PUBLIC_CONSOLE_URL=http://localhost:9001
